# =====================================================================
# CloneLM — environment configuration (copy to .env and fill in)
# Secrets live ONLY here / in the environment. Never commit .env.
# =====================================================================

# --- App ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
# Comma-separated list of allowed CORS origins for the SPA.
CORS_ORIGINS=http://localhost:5173

# --- Database (Postgres + pgvector) ---
# Matches docker-compose service. psycopg v3 driver.
DATABASE_URL=postgresql+psycopg://clonelm:clonelm@localhost:5432/clonelm

# --- LLM provider (pluggable; see domain/ports/llm.py) ---
# Options: anthropic | ollama | fake. Manageable at runtime via Einstellungen.
LLM_PROVIDER=anthropic
# The ONLY required external secret. Leave blank to fall back to the fake LLM.
ANTHROPIC_API_KEY=
# Default chat model. Exactly this id, no date suffix (see CLAUDE.md).
LLM_MODEL=claude-haiku-4-5
# Heavier model for Studio / Audio synthesis.
LLM_MODEL_HEAVY=claude-sonnet-4-6
LLM_MAX_TOKENS=1024

# Open-source local LLM via Ollama (used when LLM_PROVIDER=ollama). Run a server
# (`ollama serve`) and pull a model (`ollama pull llama3.1`). No API key needed.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
# Optional heavier model for Studio/Audio; blank reuses OLLAMA_MODEL.
OLLAMA_MODEL_HEAVY=

# --- Embeddings provider (pluggable; see domain/ports/embeddings.py) ---
# Options: bge_m3_local | fake
EMBEDDING_PROVIDER=bge_m3_local
EMBEDDING_MODEL=BAAI/bge-m3
# bge-m3 produces 1024-dim vectors. Changing this requires a re-embed +
# vector-dimension migration (the vector column is sized to this value).
EMBEDDING_DIM=1024

# --- TTS provider (stretch; pluggable; see domain/ports/tts.py) ---
# Options: piper (local neural, real speech; needs `uv sync --extra audio`) | fake (silent WAV)
TTS_PROVIDER=piper
# Piper two-host voices for the Audio Overview (auto-downloaded on first use into
# PIPER_VOICE_DIR, or via scripts/download_piper_voices.py). Dir is relative to backend/.
PIPER_VOICE_DIR=models/piper
PIPER_VOICE_HOST_A=de_DE-thorsten-medium
PIPER_VOICE_HOST_B=de_DE-kerstin-low
PIPER_SAMPLE_RATE=22050

# --- Retrieval / chunking ---
RETRIEVAL_TOP_K=8
CHUNK_TOKENS=512
CHUNK_OVERLAP=64
CHUNK_STRATEGY=token_sliding_v1
