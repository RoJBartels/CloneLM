# =====================================================================
# CloneLM — environment configuration (copy to .env and fill in)
# Secrets live ONLY here / in the environment. Never commit .env.
# =====================================================================

# --- App ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
# Comma-separated list of allowed CORS origins for the SPA.
# Localhost: the Vite dev server. Deployed: your frontend's public URL.
CORS_ORIGINS=http://localhost:5173

# Deployment mode — the single switch between the local and hosted builds.
#   false (localhost): single-user, no login; bge-m3 embeddings run locally; the
#         Settings UI also lets you pick a local open-source LLM (Ollama).
#   true  (deployed, e.g. Railway): MULTI-USER. Accounts + login are required;
#         each user brings their OWN Anthropic + Voyage keys (stored encrypted);
#         embeddings run on Voyage AI; the local-model option is hidden. Requires
#         JWT_SECRET + SECRET_ENCRYPTION_KEY below.
DEPLOYED=false

# --- Auth (only used when DEPLOYED=true) ---
# JWT signing secret — any long random string (32+ bytes recommended), e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
# Master key that encrypts each user's API keys at rest. A real Fernet key is
# preferred (any other string is hashed into one), generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=
# Session lifetime in minutes (default 7 days).
JWT_EXPIRE_MINUTES=10080
# Validate each user's keys with a tiny live request at registration (reject
# bad keys early). Set false only for offline/dev.
REGISTRATION_VERIFY_KEYS=true

# --- Database (Postgres + pgvector) ---
# Matches docker-compose service. psycopg v3 driver.
DATABASE_URL=postgresql+psycopg://clonelm:clonelm@localhost:5432/clonelm

# --- LLM provider (pluggable; see domain/ports/llm.py) ---
# Options: anthropic | ollama | fake. Manageable at runtime via Einstellungen.
LLM_PROVIDER=anthropic
# The ONLY required external secret. Leave blank to fall back to the fake LLM.
ANTHROPIC_API_KEY=
# Default chat model. Exactly this id, no date suffix (see CLAUDE.md).
LLM_MODEL=claude-haiku-4-5
# Heavier model for Studio / Audio synthesis.
LLM_MODEL_HEAVY=claude-sonnet-4-6
LLM_MAX_TOKENS=1024

# Open-source local LLM via Ollama (used when LLM_PROVIDER=ollama). Run a server
# (`ollama serve`) and pull a model (`ollama pull llama3.1`). No API key needed.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
# Optional heavier model for Studio/Audio; blank reuses OLLAMA_MODEL.
OLLAMA_MODEL_HEAVY=

# --- Embeddings provider ---
# The active embedder is NOT chosen here directly — it is derived from DEPLOYED
# so a notebook's vectors are always produced by one model:
#   DEPLOYED=false -> EMBEDDING_PROVIDER below (bge_m3_local, local).
#   DEPLOYED=true  -> Voyage AI (see VOYAGE_* below).
# Options for the local provider: bge_m3_local | fake
EMBEDDING_PROVIDER=bge_m3_local
EMBEDDING_MODEL=BAAI/bge-m3
# Vector dimension; the pgvector column is sized to this. bge-m3 AND voyage-3.5
# both emit 1024 dims, so the schema is identical in both modes. Changing this
# value requires a re-embed + vector-dimension migration.
EMBEDDING_DIM=1024

# Voyage AI (an Anthropic company, but authenticates with its OWN key — NOT the
# Anthropic key; https://dash.voyageai.com). In the MULTI-USER deployed build the
# key is per-user (each user enters their own at registration), so the server
# does NOT need VOYAGE_API_KEY. It is only a single-tenant fallback. voyage-3.5
# defaults to 1024-dim output, matching EMBEDDING_DIM.
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3.5

# --- TTS provider (stretch; pluggable; see domain/ports/tts.py) ---
# Options: piper (local neural, real speech; needs `uv sync --extra audio`) | fake (silent WAV)
TTS_PROVIDER=piper
# Piper two-host voices for the Audio Overview (auto-downloaded on first use into
# PIPER_VOICE_DIR, or via scripts/download_piper_voices.py). Dir is relative to backend/.
PIPER_VOICE_DIR=models/piper
PIPER_VOICE_HOST_A=de_DE-thorsten-medium
PIPER_VOICE_HOST_B=de_DE-kerstin-low
PIPER_SAMPLE_RATE=22050

# --- Retrieval / chunking ---
RETRIEVAL_TOP_K=8
CHUNK_TOKENS=512
CHUNK_OVERLAP=64
CHUNK_STRATEGY=token_sliding_v1
